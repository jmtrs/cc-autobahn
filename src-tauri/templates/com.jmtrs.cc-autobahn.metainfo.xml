<?xml version="1.0" encoding="UTF-8"?>
<!--
  AppStream metadata for cc-autobahn. Installed to /usr/share/metainfo/ by
  the Debian bundle (bundle.linux.deb.files) so software centers (GNOME
  Software, KDE Discover) can present the app. The desktop-id must match the
  generated .desktop filename basename (D59).
-->
<component type="desktop-application">
  <id>com.jmtrs.cc-autobahn</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>cc-autobahn</name>
  <summary>Mercedes W203 instrument cluster for Claude Code and Codex usage</summary>
  <description>
    <p>
      cc-autobahn is a menu-bar instrument cluster styled after the amber VFD
      display of the Mercedes W203, showing Claude Code and Codex token
      consumption: tok/s per response, cost, the 5-hour billing window, and
      model selection.
    </p>
  </description>
  <launchable type="desktop-id">com.jmtrs.cc-autobahn.desktop</launchable>
  <provides>
    <binary>cc-autobahn</binary>
  </provides>
  <recommends>
    <control>pointing</control>
    <control>keyboard</control>
  </recommends>
  <content_rating type="oars-1.1" />
  <url type="homepage">https://github.com/jmtrs/cc-autobahn</url>
  <releases>
    <release version="0.9.0" date="2026-07-21">
      <description>
        <p>Initial Linux distribution (.deb, .rpm, .AppImage).</p>
      </description>
    </release>
  </releases>
</component>
